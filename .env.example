# App
PUBLIC_APP_URL=https://yourwallpaper.app
PUBLIC_APP_NAME=YourWallpaper

# Supabase — Project Settings > API
PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe — Developers > API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — Products > Prices (créer les produits dans le dashboard Stripe)
STRIPE_PRICE_ONE_SHOT=price_...       # One-shot pack €2.99
STRIPE_PRICE_PRO_MONTHLY=price_...   # Pro mensuel €4.99
STRIPE_PRICE_PRO_ANNUAL=price_...    # Pro annuel €29
STRIPE_PRICE_COMMERCIAL=price_...    # License commerciale €99

# Cloudflare R2 — R2 > Manage R2 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=yourwallpaper-assets
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Umami Analytics (optionnel pour le MVP)
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js

# Sentry (optionnel)
SENTRY_DSN=
PUBLIC_SENTRY_DSN=

# Sécurité
IP_HASH_SALT=change-me-to-a-random-string

# Paiements — passer à true quand Stripe est configuré
PUBLIC_PAYMENT_ENABLED=false
